# MongoDB Atlas Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?appName=Cluster0

# Voyage / Atlas AI Models Configuration
VOYAGE_API_KEY=your_model_api_key_here
VOYAGE_EMBEDDINGS_URL=https://ai.mongodb.com/v1/embeddings
EMBEDDING_MODEL=voyage-3-large

# Production-safe embedding limits
# Maximum number of embedding requests that can be sent to the Voyage / Atlas AI embeddings endpoint per minute 
VOYAGE_REQUESTS_PER_MINUTE=300
# Maximum number of tokens that can be sent to the Voyage / Atlas AI embeddings endpoint per minute
VOYAGE_TOKENS_PER_MINUTE=100000

# Maximum number of tokens to send in a single embedding request batch (The total number of tokens in all the inputs sent in a single embedding request batch must not exceed this value)
MAX_EMBEDDING_BATCH_TOKENS=50000
# Maximum number of embedding requests to send in a single batch
MAX_EMBEDDING_BATCH_SIZE=12

# Delay between embedding requests in milliseconds to avoid hitting rate limits (Sleep for this duration between requests)
EMBEDDING_REQUEST_DELAY_MS=250

# Maximum number of times to retry an embedding request in case of failure(If an embedding request fails, retry this many times before giving up)
EMBEDDING_MAX_RETRIES=5
# Delay in milliseconds to wait before retrying a failed embedding request (Wait until this duration before attempting the next retry after an embedding request fails)
EMBEDDING_RETRY_DELAY_MS=5000

# Query cost estimation
# Leave these at 0 if you only want token estimates without dollar estimates.
EMBEDDING_COST_PER_1M_TOKENS=0
LLM_INPUT_COST_PER_1M_TOKENS=0
LLM_OUTPUT_COST_PER_1M_TOKENS=0
ESTIMATED_LLM_COMPLETION_TOKENS=0

# chunking / splitting configuration
TARGET_CHUNK_MIN_TOKENS=400
TARGET_CHUNK_MAX_TOKENS=700
# The maximum number of tokens in a chunk before it should be forcibly split into smaller chunks (If a chunk exceeds this number of tokens
# it will be split into smaller chunks to avoid sending overly large chunks to the embedding endpoint)
HARD_CHUNK_SPLIT_THRESHOLD=800
# The number of tokens to overlap between chunks when splitting an oversized block into smaller chunks to avoid losing context (When a chunk is split into smaller chunks because it exceeds the HARD_CHUNK_SPLIT_THRESHOLD, this number of tokens from the end of the previous chunk will be included at the start of the next chunk so that context is preserved across the split)
OVERSIZED_BLOCK_OVERLAP_TOKENS=60

# Seeder controls
# Basically if it is true then the seeder will delete the standards collection before seeding the data
RESET_COLLECTION=false

# used for debugging the database seeding process without actually writing to the database (Only for checking whethere the seeding logic works as expected or not)
DRY_RUN=false
